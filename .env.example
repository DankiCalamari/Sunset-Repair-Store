# Application
APP_NAME=Sunset Country Tech ERP
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
APP_URL=http://localhost:5173
API_URL=http://localhost:8000

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=sunset
POSTGRES_PASSWORD=sunset_dev_password
POSTGRES_DB=sunset_erp

DATABASE_URL=postgresql+asyncpg://sunset:sunset_dev_password@db:5432/sunset_erp

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=sunset-erp
S3_REGION=us-east-1
S3_USE_SSL=false
S3_PUBLIC_URL=http://localhost:9000

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@sunsetcountry.tech

# SMS (Twilio-style placeholder)
SMS_PROVIDER=
SMS_API_KEY=
SMS_FROM_NUMBER=

# Redis (optional cache / pub-sub for WebSockets scale-out)
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
