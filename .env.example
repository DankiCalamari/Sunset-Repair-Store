# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=Repair Shop ERP
APP_ENV=production
APP_DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_HEX
APP_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com
VITE_API_URL=/api

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=REPLACE_DB_USER
POSTGRES_PASSWORD=REPLACE_DB_PASSWORD
POSTGRES_DB=REPLACE_DB_NAME

DATABASE_URL=postgresql+asyncpg://REPLACE_DB_USER:REPLACE_DB_PASSWORD@db:5432/REPLACE_DB_NAME

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_HEX
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── S3 / Object storage ──────────────────────────────────────────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=REPLACE_S3_ACCESS_KEY
S3_SECRET_KEY=REPLACE_S3_SECRET_KEY
S3_BUCKET=REPLACE_S3_BUCKET_NAME
S3_REGION=ap-southeast-2
S3_USE_SSL=true
S3_PUBLIC_URL=https://REPLACE_S3_BUCKET_NAME.s3.ap-southeast-2.amazonaws.com

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USERNAME=REPLACE_SMTP_USER
SMTP_PASSWORD=REPLACE_SMTP_PASSWORD
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_TLS=true
# Set true when using implicit SSL on port 465 (optional; port 465 auto-detects SSL)
SMTP_USE_SSL=false

# ─── SMS ──────────────────────────────────────────────────────────────────────
SMS_PROVIDER=telnyx
SMS_API_KEY=REPLACE_SMS_API_KEY
SMS_FROM_NUMBER=REPLACE_FROM_NUMBER

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://yourdomain.com
